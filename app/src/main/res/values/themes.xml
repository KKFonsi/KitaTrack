<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.KitaTrack" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/kitatrack_primary_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/kitatrack_soft_mint</item>
        <item name="colorOnSecondary">@color/kitatrack_primary_text</item>
        <item name="colorTertiary">@color/kitatrack_warning_yellow</item>
        <item name="colorSurface">@color/kitatrack_card_background</item>
        <item name="colorSurfaceVariant">@color/kitatrack_secondary_background</item>
        <item name="colorOutline">@color/kitatrack_subtle_border</item>
        <item name="android:colorAccent">@color/kitatrack_primary_green</item>
        <item name="android:windowBackground">@color/kitatrack_background</item>
        <item name="android:fontFamily">sans</item>
        <item name="materialCardViewStyle">@style/Widget.KitaTrack.Card</item>
    </style>

    <style name="Theme.KitaTrack" parent="Base.Theme.KitaTrack" />

    <style name="Widget.KitaTrack.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/kitatrack_soft_mint</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="KitaTrackFullCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="cardBackgroundColor">@color/kitatrack_card_background</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/kitatrack_subtle_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="KitaTrackSmallCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">@color/kitatrack_card_background</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/kitatrack_subtle_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="KitaTrackCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="KitaTrackCardLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/kitatrack_secondary_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="KitaTrackCardAmount">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/kitatrack_primary_text</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KitaTrackSectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/kitatrack_primary_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="KitaTrackScreenTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/kitatrack_primary_text</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KitaTrackScreenSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/kitatrack_secondary_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="KitaTrackStatusChipText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/kitatrack_primary_green</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingRight">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:background">@drawable/kt_chip_green</item>
    </style>

    <style name="KitaTrackBodyText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/kitatrack_secondary_text</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>

