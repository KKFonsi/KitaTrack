<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/kt_bottom_sheet_background"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="12dp"
    android:paddingEnd="22dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kt_sheet_handle" />

    <TextView
        android:id="@+id/debt_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Add Debt"
        android:textColor="@color/kitatrack_primary_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/debt_dialog_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="18dp">

            <TextView style="@style/KitaTrackFormLabel" android:text="DEBT NAME" />
            <com.google.android.material.textfield.TextInputLayout style="@style/KitaTrackFormField" android:hint="e.g. Phone loan">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/debt_name_input" style="@style/KitaTrackFormEditText" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="PERSON / LENDER" />
            <com.google.android.material.textfield.TextInputLayout style="@style/KitaTrackFormField" android:hint="e.g. Lazada, Juan">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/debt_person_input" style="@style/KitaTrackFormEditText" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="DEBT TYPE" />
            <LinearLayout
                android:id="@+id/debt_type_chip_row"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/debt_i_owe_chip"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="Money I owe"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/debt_owed_to_me_chip"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="Money owed to me"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/debt_type_context"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/kt_form_field_background"
                android:padding="12dp"
                android:text="Creates a Debt Reserve: money is set aside from your balance to pay this debt."
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="12sp" />

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="TOTAL AMOUNT" />
            <com.google.android.material.textfield.TextInputLayout style="@style/KitaTrackFormField.Amount" android:hint="0.00">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/debt_total_input" style="@style/KitaTrackFormEditText" android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="AMOUNT ALREADY PAID" />
            <com.google.android.material.textfield.TextInputLayout style="@style/KitaTrackFormField.Amount" android:hint="0.00">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/debt_paid_input" style="@style/KitaTrackFormEditText" android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="PAYMENT AMOUNT" />
            <com.google.android.material.textfield.TextInputLayout style="@style/KitaTrackFormField.Amount" android:hint="0.00">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/debt_installment_input" style="@style/KitaTrackFormEditText" android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="PAYMENT FREQUENCY" />
            <LinearLayout
                android:id="@+id/debt_frequency_chip_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/debt_freq_one_time_chip"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:text="One-time"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/debt_freq_weekly_chip"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:text="Weekly"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/debt_freq_bi_weekly_chip"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:text="Bi-weekly"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/debt_freq_monthly_chip"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:text="Monthly"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/debt_freq_daily_chip"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:text="Daily"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/debt_freq_custom_chip"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:text="Custom"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/debt_interval_layout"
                style="@style/KitaTrackFormField"
                android:layout_marginTop="12dp"
                android:hint="Every X days">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/debt_interval_input" style="@style/KitaTrackFormEditText" android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="NEXT DUE DATE" />
            <com.google.android.material.textfield.TextInputLayout
                style="@style/KitaTrackFormField"
                android:hint="Pick a date"
                app:startIconDrawable="@drawable/ic_calendar_24"
                app:startIconTint="@color/kitatrack_secondary_text">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/debt_due_input"
                    style="@style/KitaTrackFormEditText"
                    android:clickable="true"
                    android:focusable="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView style="@style/KitaTrackFormLabel" android:layout_marginTop="14dp" android:text="NOTES" />
            <com.google.android.material.textfield.TextInputLayout style="@style/KitaTrackFormField" android:hint="Any notes...">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/debt_notes_input"
                    style="@style/KitaTrackFormEditText"
                    android:gravity="top|start"
                    android:maxLines="3"
                    android:minLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/debt_auto_reserve_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Auto reserve from income"
                android:textColor="@color/kitatrack_primary_text" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/debt_reminder_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show in-app reminder status"
                android:textColor="@color/kitatrack_primary_text" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/debt_active_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textColor="@color/kitatrack_primary_text" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/debt_save_button"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/kitatrack_primary_green"
        android:text="Save Debt"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/debt_cancel_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="@color/kitatrack_secondary_text" />
</LinearLayout>
