<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/kitatrack_card_background"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="34dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/kitatrack_divider" />

    <TextView
        android:id="@+id/detail_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:textColor="@color/kitatrack_primary_green"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/detail_type_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/kt_chip_green"
        android:paddingStart="12dp"
        android:paddingTop="5dp"
        android:paddingEnd="12dp"
        android:paddingBottom="5dp"
        android:textColor="@color/kitatrack_primary_green"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="vertical">

        <include
            android:id="@+id/detail_category_row"
            layout="@layout/item_transaction_detail_row" />

        <include
            android:id="@+id/detail_date_row"
            layout="@layout/item_transaction_detail_row" />

        <include
            android:id="@+id/detail_account_row"
            layout="@layout/item_transaction_detail_row" />

        <include
            android:id="@+id/detail_note_row"
            layout="@layout/item_transaction_detail_row" />

        <include
            android:id="@+id/detail_balance_row"
            layout="@layout/item_transaction_detail_row" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detail_edit_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Edit"
            android:textAllCaps="false"
            app:cornerRadius="12dp" />

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detail_delete_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="@color/kitatrack_expense_red"
            app:backgroundTint="@color/kitatrack_soft_danger_background"
            app:cornerRadius="12dp" />
    </LinearLayout>
</LinearLayout>
