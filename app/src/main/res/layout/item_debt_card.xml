<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    app:cardBackgroundColor="@color/kitatrack_plan_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/kitatrack_subtle_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/debt_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/debt_status"
                style="@style/KitaTrackStatusChipText" />

            <TextView
                android:id="@+id/debt_due_chip"
                style="@style/KitaTrackStatusChipText"
                android:layout_marginStart="6dp"
                android:background="@drawable/kt_chip_green"
                android:textColor="@color/kitatrack_secondary_text"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/debt_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/debt_amounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/debt_figures_row"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Remaining"
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/debt_remaining_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/kitatrack_expense_red"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View style="@style/KitaTrackSettingsDivider"
                android:layout_width="1dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Payment"
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/debt_payment_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View style="@style/KitaTrackSettingsDivider"
                android:layout_width="1dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Paid"
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/debt_paid_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/debt_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="14dp"
            android:max="100"
            android:progressBackgroundTint="@color/kitatrack_divider"
            android:progressTint="@color/kitatrack_primary_green" />

        <TextView
            android:id="@+id/debt_percent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
