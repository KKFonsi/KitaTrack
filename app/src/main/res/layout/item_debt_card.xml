<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
    app:cardBackgroundColor="@color/kitatrack_soft_warning_background" app:cardCornerRadius="24dp" app:strokeColor="@color/kitatrack_subtle_border" app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView android:id="@+id/debt_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="@color/kitatrack_primary_text" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/debt_status" style="@style/KitaTrackStatusChipText" android:background="@drawable/kt_chip_yellow" android:textColor="@color/kitatrack_secondary_text" />
        </LinearLayout>
        <TextView android:id="@+id/debt_meta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/kitatrack_secondary_text" />
        <TextView android:id="@+id/debt_amounts" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/kitatrack_primary_text" android:textSize="16sp" />
        <ProgressBar android:id="@+id/debt_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="12dp" android:max="100" android:progressBackgroundTint="@color/kitatrack_divider" android:progressTint="@color/kitatrack_primary_green" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
