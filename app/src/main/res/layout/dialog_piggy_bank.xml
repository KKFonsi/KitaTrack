<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/kt_bottom_sheet_background"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="12dp"
    android:paddingEnd="22dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kt_sheet_handle" />

    <TextView
        android:id="@+id/piggy_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Add Piggy Bank"
        android:textColor="@color/kitatrack_primary_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/piggy_dialog_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GOAL NAME"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="e.g. Emergency Fund"
                app:boxBackgroundColor="@color/kitatrack_secondary_background"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/kitatrack_subtle_border">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/piggy_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="TARGET AMOUNT"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="0.00"
                app:boxBackgroundColor="@color/kitatrack_secondary_background"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/kitatrack_subtle_border"
                app:prefixText="₱ "
                app:prefixTextColor="@color/kitatrack_primary_green">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/piggy_target_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:singleLine="true"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="WEEKLY INCOME PREDICTION"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Used to estimate completion"
                app:boxBackgroundColor="@color/kitatrack_secondary_background"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/kitatrack_subtle_border"
                app:prefixText="₱ "
                app:prefixTextColor="@color/kitatrack_primary_green">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/piggy_weekly_income_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:singleLine="true"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="TARGET DATE"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Pick a date"
                app:boxBackgroundColor="@color/kitatrack_secondary_background"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/kitatrack_subtle_border"
                app:startIconDrawable="@drawable/ic_calendar_24"
                app:startIconTint="@color/kitatrack_secondary_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/piggy_target_date_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:singleLine="true"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="NOTES"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Any notes about this goal..."
                app:boxBackgroundColor="@color/kitatrack_secondary_background"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/kitatrack_subtle_border">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/piggy_notes_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:maxLines="3"
                    android:minLines="2"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/piggy_plan_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/kt_form_field_background"
                android:lineSpacingExtra="2dp"
                android:padding="12dp"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="13sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/piggy_percent_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/piggy_selected_percent_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/piggy_over_save_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="48dp"
                android:text="Allow over-saving"
                android:textColor="@color/kitatrack_primary_text" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/piggy_active_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="Active"
                android:textColor="@color/kitatrack_primary_text" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/piggy_save_button"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/kitatrack_primary_green"
        android:text="Save Piggy Bank"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/piggy_cancel_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="@color/kitatrack_secondary_text" />
</LinearLayout>
