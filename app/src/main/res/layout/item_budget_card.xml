<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    app:cardBackgroundColor="@color/kitatrack_plan_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/kitatrack_subtle_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/kt_category_icon_circle">

                <ImageView
                    android:id="@+id/budget_category_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    app:tint="@color/kitatrack_secondary_text" />
            </FrameLayout>

            <TextView
                android:id="@+id/budget_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/budget_status"
                style="@style/KitaTrackStatusChipText"
                android:background="@drawable/kt_chip_green"
                android:textColor="@color/kitatrack_secondary_text" />
        </LinearLayout>

        <TextView
            android:id="@+id/budget_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/budget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="14dp"
            android:max="100"
            android:progressBackgroundTint="@color/kitatrack_divider"
            android:progressTint="@color/kitatrack_primary_green" />

        <TextView
            android:id="@+id/budget_amounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/budget_left"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/budget_used"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:id="@+id/budget_reserved_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:background="@color/kitatrack_divider"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/budget_reserved_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reserved this period"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/budget_reserved_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kitatrack_primary_green"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
