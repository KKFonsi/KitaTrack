<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kitatrack_background"
    android:orientation="vertical"
    android:padding="20dp">
    <TextView
        style="@style/KitaTrackScreenTitle"
        android:text="History" />
    <TextView
        style="@style/KitaTrackScreenSubtitle"
        android:text="Your money flow, grouped by day." />
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/history_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:singleSelection="true">
        <com.google.android.material.chip.Chip android:id="@+id/filter_all" style="@style/Widget.Material3.Chip.Filter" app:checkedIconVisible="false" app:chipCornerRadius="18dp" app:chipBackgroundColor="@color/kt_filter_chip_background" app:chipStrokeColor="@color/kitatrack_subtle_border" app:chipStrokeWidth="1dp" android:textColor="@color/kt_filter_chip_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="All" android:checked="true" />
        <com.google.android.material.chip.Chip android:id="@+id/filter_income" style="@style/Widget.Material3.Chip.Filter" app:checkedIconVisible="false" app:chipCornerRadius="18dp" app:chipBackgroundColor="@color/kt_filter_chip_background" app:chipStrokeColor="@color/kitatrack_subtle_border" app:chipStrokeWidth="1dp" android:textColor="@color/kt_filter_chip_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Income" />
        <com.google.android.material.chip.Chip android:id="@+id/filter_expense" style="@style/Widget.Material3.Chip.Filter" app:checkedIconVisible="false" app:chipCornerRadius="18dp" app:chipBackgroundColor="@color/kt_filter_chip_background" app:chipStrokeColor="@color/kitatrack_subtle_border" app:chipStrokeWidth="1dp" android:textColor="@color/kt_filter_chip_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expense" />
        <com.google.android.material.chip.Chip android:id="@+id/filter_this_week" style="@style/Widget.Material3.Chip.Filter" app:checkedIconVisible="false" app:chipCornerRadius="18dp" app:chipBackgroundColor="@color/kt_filter_chip_background" app:chipStrokeColor="@color/kitatrack_subtle_border" app:chipStrokeWidth="1dp" android:textColor="@color/kt_filter_chip_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This Week" />
        <com.google.android.material.chip.Chip android:id="@+id/filter_this_month" style="@style/Widget.Material3.Chip.Filter" app:checkedIconVisible="false" app:chipCornerRadius="18dp" app:chipBackgroundColor="@color/kt_filter_chip_background" app:chipStrokeColor="@color/kitatrack_subtle_border" app:chipStrokeWidth="1dp" android:textColor="@color/kt_filter_chip_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This Month" />
    </com.google.android.material.chip.ChipGroup>
    <TextView
        android:id="@+id/history_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/kt_card_warning"
        android:padding="18dp"
        android:text="Nothing tracked yet. Add your first income or expense to start seeing your money flow."
        android:textColor="@color/kitatrack_secondary_text" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/history_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />
</LinearLayout>



