<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/kt_bottom_sheet_background"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kt_sheet_handle" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detail_sheet_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/kitatrack_primary_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detail_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textColor="@color/kitatrack_secondary_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/detail_status_badge"
                    style="@style/KitaTrackStatusChipText"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/detail_direction_badge"
                style="@style/KitaTrackStatusChipText"
                android:layout_marginTop="14dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/detail_amount_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/detail_main_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_amount_context"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/detail_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="7dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progressBackgroundTint="@color/kitatrack_divider"
                android:progressTint="@color/kitatrack_primary_green" />

            <TextView
                android:id="@+id/detail_progress_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/detail_stats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/kt_form_field_background"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <LinearLayout
                android:id="@+id/detail_extra_actions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/detail_primary_button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="@color/kitatrack_primary_green"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="14dp" />

    <LinearLayout
        android:id="@+id/detail_secondary_row"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detail_secondary_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:includeFontPadding="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:maxLines="2"
            android:minHeight="52dp"
            android:minWidth="0dp"
            android:textAllCaps="false"
            android:textColor="@color/kitatrack_primary_green"
            android:textSize="13sp"
            app:cornerRadius="14dp"
            app:strokeColor="@color/kitatrack_primary_green" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detail_edit_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="52dp"
            android:minWidth="0dp"
            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="@color/kitatrack_primary_text"
            app:cornerRadius="14dp"
            app:strokeColor="@color/kitatrack_subtle_border" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/detail_close_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="2dp"
        android:text="Close"
        android:textAllCaps="false"
        android:textColor="@color/kitatrack_secondary_text" />
</LinearLayout>
