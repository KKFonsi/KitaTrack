<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/kt_bottom_sheet_background"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="12dp"
    android:paddingEnd="22dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kt_sheet_handle" />

    <TextView
        android:id="@+id/budget_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Add Budget"
        android:textColor="@color/kitatrack_primary_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="BUDGET NAME"
        android:textColor="@color/kitatrack_secondary_text"
        android:textSize="11sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="e.g. Food &amp; Drinks"
        app:boxBackgroundColor="@color/kitatrack_secondary_background"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/kitatrack_subtle_border">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/budget_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="LIMIT AMOUNT"
        android:textColor="@color/kitatrack_secondary_text"
        android:textSize="11sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="0.00"
        app:boxBackgroundColor="@color/kitatrack_secondary_background"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/kitatrack_subtle_border"
        app:prefixText="₱ "
        app:prefixTextColor="@color/kitatrack_primary_green">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/budget_amount_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="BUDGET PERIOD"
        android:textColor="@color/kitatrack_secondary_text"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/budget_period_chip_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/budget_weekly_chip"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Weekly"
            android:textAllCaps="false"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/budget_monthly_chip"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="Monthly"
            android:textAllCaps="false"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/budget_category_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="CATEGORY"
        android:textColor="@color/kitatrack_secondary_text"
        android:textSize="11sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/budget_category_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="Select category"
        app:boxBackgroundColor="@color/kitatrack_secondary_background"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/kitatrack_subtle_border"
        app:endIconMode="dropdown_menu"
        app:hintEnabled="false">

        <AutoCompleteTextView
            android:id="@+id/budget_category_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/budget_category_help"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Choose the spending category this budget should track."
        android:textColor="@color/kitatrack_muted_text"
        android:textSize="12sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/budget_active_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:minHeight="48dp"
        android:text="Active"
        android:textColor="@color/kitatrack_primary_text" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/budget_save_button"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:backgroundTint="@color/kitatrack_primary_green"
        android:text="Save Budget"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/budget_cancel_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="@color/kitatrack_secondary_text" />
</LinearLayout>
