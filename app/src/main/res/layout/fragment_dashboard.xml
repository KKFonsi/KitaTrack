<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kt_screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="KitaTrack"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/theme_toggle_button"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Toggle dark mode"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/kitatrack_elevated_card_background"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_theme_moon"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/kitatrack_primary_text" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/kitatrack_safe_balance_highlight"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_strong_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="SAFE TO SPEND"
                    android:textColor="@color/kitatrack_primary_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/main_balance_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/add_income_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="50dp"
                        android:text="+ Income"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/kitatrack_primary_green"
                        app:cornerRadius="16dp" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/add_expense_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="50dp"
                        android:text="- Expense"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/kitatrack_expense_red"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="This Month" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/KitaTrackCardLabel"
                            android:text="Income" />

                        <TextView
                            android:id="@+id/month_income_value"
                            style="@style/KitaTrackCardAmount"
                            android:textColor="@color/kitatrack_primary_green" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="42dp"
                        android:background="@color/kitatrack_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/KitaTrackCardLabel"
                            android:text="Expenses" />

                        <TextView
                            android:id="@+id/month_expenses_value"
                            style="@style/KitaTrackCardAmount"
                            android:textColor="@color/kitatrack_expense_red" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="42dp"
                        android:background="@color/kitatrack_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/KitaTrackCardLabel"
                            android:text="Net" />

                        <TextView
                            android:id="@+id/month_net_value"
                            style="@style/KitaTrackCardAmount" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_soft_planner_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/smart_insight_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:padding="16dp"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/KitaTrackSectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reserved Money"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/reserved_total_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="13sp" />
        </LinearLayout>

        <include
            android:id="@+id/debt_reserve_card"
            layout="@layout/item_dashboard_reserve_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <include
            android:id="@+id/piggy_reserve_card"
            layout="@layout/item_dashboard_reserve_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <include
            android:id="@+id/subscription_reserve_card"
            layout="@layout/item_dashboard_reserve_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/obligations_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_soft_warning_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_warning_yellow"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/obligations_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:padding="16dp"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/KitaTrackSectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Budget Pulse"
                android:textSize="20sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/view_plans_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:text="See all"
                android:textAllCaps="false"
                android:textColor="@color/kitatrack_primary_green" />
        </LinearLayout>

        <include
            android:id="@+id/budget_first_card"
            layout="@layout/item_dashboard_budget_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <include
            android:id="@+id/budget_second_card"
            layout="@layout/item_dashboard_budget_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <include
            android:id="@+id/budget_third_card"
            layout="@layout/item_dashboard_budget_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/budget_empty_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/budget_empty_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="No active budgets"
                android:textColor="@color/kitatrack_secondary_text"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/KitaTrackSectionTitle"
            android:layout_marginTop="22dp"
            android:text="Savings Goal"
            android:textSize="20sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/piggy_goal_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/kitatrack_primary_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/piggy_goal_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/kitatrack_primary_green"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/piggy_overview_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/piggy_goal_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/kitatrack_divider"
                    android:progressTint="@color/kitatrack_primary_green" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
