<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kitatrack_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Dashboard" android:textColor="@color/kitatrack_primary_text"
            android:textSize="28sp" android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" app:cardBackgroundColor="@color/kitatrack_primary_green">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Main Balance" android:textColor="@color/white" android:textSize="15sp" />
                <TextView android:id="@+id/main_balance_value" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginTop="6dp"
                    android:textColor="@color/white" android:textSize="32sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="Safe to spend"
                    android:textColor="@color/white" android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_income_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="52dp"
                android:text="Add Income"
                android:textAllCaps="false" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_expense_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="52dp"
                android:text="Add Expense"
                android:textAllCaps="false"
                app:backgroundTint="@color/kitatrack_expense_red" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:text="Piggy Bank Total" android:textColor="@color/kitatrack_secondary_text" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/piggy_bank_total_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/kitatrack_primary_text" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space android:layout_width="12dp" android:layout_height="1dp"/>
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:text="Total Money Tracked" android:textColor="@color/kitatrack_secondary_text" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/total_money_tracked_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/kitatrack_primary_text" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="This Month Income" android:textColor="@color/kitatrack_secondary_text" />
                    <TextView android:id="@+id/month_income_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:textColor="@color/kitatrack_primary_green" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="This Month Expenses" android:textColor="@color/kitatrack_secondary_text" />
                    <TextView android:id="@+id/month_expenses_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:textColor="@color/kitatrack_expense_red" android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Budget Overview" android:textColor="@color/kitatrack_primary_text" android:textStyle="bold"/>
                <TextView android:id="@+id/weekly_budget_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:textColor="@color/kitatrack_secondary_text"/>
                <TextView android:id="@+id/monthly_budget_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/kitatrack_secondary_text"/>
                <TextView android:id="@+id/budget_warning_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:textColor="@color/kitatrack_warning_yellow"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:text="Piggy Bank Overview" android:textColor="@color/kitatrack_primary_text" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/piggy_overview_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/kitatrack_secondary_text"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="This Month Net" android:textColor="@color/kitatrack_secondary_text" />
                    <TextView android:id="@+id/month_net_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:textColor="@color/kitatrack_primary_green" android:textSize="20sp" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:text="Top Category" android:textColor="@color/kitatrack_secondary_text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/top_category_value" android:textColor="@color/kitatrack_primary_text"
                        android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.card.MaterialCardView android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:text="Highest Expense" android:textColor="@color/kitatrack_secondary_text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/highest_expense_value" android:textColor="@color/kitatrack_expense_red"
                        android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="24dp" android:text="Recent Transactions"
            android:textColor="@color/kitatrack_primary_text" android:textSize="20sp" android:textStyle="bold" />
        <TextView android:id="@+id/recent_empty_state" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="12dp"
            android:text="No transactions yet. Start by adding your first income or expense."
            android:textColor="@color/kitatrack_secondary_text" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/recent_transactions_list"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>
