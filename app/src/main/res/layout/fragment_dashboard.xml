<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kitatrack_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/kitatrack_soft_mint"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Main Balance"
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/main_balance_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/kitatrack_primary_green"
                    android:textSize="34sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Safe to spend"
                    android:textColor="@color/kitatrack_muted_text"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_income_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="52dp"
                android:text="Add Income"
                android:textAllCaps="false" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_expense_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="52dp"
                android:text="Add Expense"
                android:textAllCaps="false"
                app:backgroundTint="@color/kitatrack_expense_red" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView style="@style/KitaTrackSmallCard" android:layout_width="0dp" android:layout_weight="1">
                <LinearLayout style="@style/KitaTrackCardContent">
                    <TextView style="@style/KitaTrackCardLabel" android:text="Debt Reserve" />
                    <TextView android:id="@+id/debt_reserve_value" style="@style/KitaTrackCardAmount" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.card.MaterialCardView style="@style/KitaTrackSmallCard" android:layout_width="0dp" android:layout_weight="1">
                <LinearLayout style="@style/KitaTrackCardContent">
                    <TextView style="@style/KitaTrackCardLabel" android:text="Piggy Bank Total" />
                    <TextView android:id="@+id/piggy_bank_total_value" style="@style/KitaTrackCardAmount" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackCardLabel" android:text="Subscription Reserve" />
                <TextView android:id="@+id/subscription_reserve_value" style="@style/KitaTrackCardAmount" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackCardLabel" android:text="Total Money Tracked" />
                <TextView android:id="@+id/total_money_tracked_value" style="@style/KitaTrackCardAmount" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView style="@style/KitaTrackSmallCard" android:layout_width="0dp" android:layout_weight="1">
                <LinearLayout style="@style/KitaTrackCardContent">
                    <TextView style="@style/KitaTrackCardLabel" android:text="This Month Income" />
                    <TextView android:id="@+id/month_income_value" style="@style/KitaTrackCardAmount" android:textColor="@color/kitatrack_primary_green" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.card.MaterialCardView style="@style/KitaTrackSmallCard" android:layout_width="0dp" android:layout_weight="1">
                <LinearLayout style="@style/KitaTrackCardContent">
                    <TextView style="@style/KitaTrackCardLabel" android:text="This Month Expenses" />
                    <TextView android:id="@+id/month_expenses_value" style="@style/KitaTrackCardAmount" android:textColor="@color/kitatrack_expense_red" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackCardLabel" android:text="This Month Net" />
                <TextView android:id="@+id/month_net_value" style="@style/KitaTrackCardAmount" android:textColor="@color/kitatrack_primary_green" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackSectionTitle" android:text="Debt Overview" />
                <TextView android:id="@+id/debt_overview_value" style="@style/KitaTrackBodyText" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackSectionTitle" android:text="Subscription Overview" />
                <TextView android:id="@+id/subscription_overview_value" style="@style/KitaTrackBodyText" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackSectionTitle" android:text="Budget Overview" />
                <TextView android:id="@+id/weekly_budget_value" style="@style/KitaTrackBodyText" android:layout_marginTop="8dp" />
                <TextView android:id="@+id/monthly_budget_value" style="@style/KitaTrackBodyText" android:layout_marginTop="4dp" />
                <TextView android:id="@+id/budget_warning_value" style="@style/KitaTrackBodyText" android:layout_marginTop="8dp" android:textColor="@color/kitatrack_warning_yellow" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView style="@style/KitaTrackFullCard">
            <LinearLayout style="@style/KitaTrackCardContent">
                <TextView style="@style/KitaTrackSectionTitle" android:text="Piggy Bank Overview" />
                <TextView android:id="@+id/piggy_overview_value" style="@style/KitaTrackBodyText" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView style="@style/KitaTrackSmallCard" android:layout_width="0dp" android:layout_weight="1">
                <LinearLayout style="@style/KitaTrackCardContent">
                    <TextView style="@style/KitaTrackCardLabel" android:text="Top Category" />
                    <TextView android:id="@+id/top_category_value" style="@style/KitaTrackCardAmount" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.card.MaterialCardView style="@style/KitaTrackSmallCard" android:layout_width="0dp" android:layout_weight="1">
                <LinearLayout style="@style/KitaTrackCardContent">
                    <TextView style="@style/KitaTrackCardLabel" android:text="Highest Expense" />
                    <TextView android:id="@+id/highest_expense_value" style="@style/KitaTrackCardAmount" android:textColor="@color/kitatrack_expense_red" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Recent Transactions"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/recent_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No transactions yet. Start by adding your first income or expense."
            android:textColor="@color/kitatrack_secondary_text" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recent_transactions_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>


