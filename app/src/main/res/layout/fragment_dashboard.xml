<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kt_screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/KitaTrackScreenTitle"
            android:text="Dashboard" />
        <TextView
            style="@style/KitaTrackScreenSubtitle"
            android:text="Here is what is safe to spend today." />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/kitatrack_safe_balance_highlight"
            app:cardCornerRadius="28dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/kitatrack_strong_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/kt_hero_card_background"
                android:orientation="vertical"
                android:padding="22dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/kt_icon_circle"
                        android:gravity="center"
                        android:text="PHP"
                        android:textColor="@color/kitatrack_primary_green"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Safe to spend"
                            android:textColor="@color/kitatrack_primary_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="After reserves and planned payments"
                            android:textColor="@color/kitatrack_secondary_text"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:id="@+id/main_balance_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/kitatrack_primary_green"
                    android:textSize="36sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_income_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="54dp"
                android:text="+ Income"
                android:textAllCaps="false"
                app:cornerRadius="28dp" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_expense_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="54dp"
                android:text="- Expense"
                android:textAllCaps="false"
                app:backgroundTint="@color/kitatrack_expense_red"
                app:cornerRadius="28dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="This Month" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/KitaTrackCardLabel" android:text="Income" />
                        <TextView android:id="@+id/month_income_value" style="@style/KitaTrackCardAmount" android:textColor="@color/kitatrack_primary_green" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/KitaTrackCardLabel" android:text="Expenses" />
                        <TextView android:id="@+id/month_expenses_value" style="@style/KitaTrackCardAmount" android:textColor="@color/kitatrack_expense_red" />
                    </LinearLayout>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/kitatrack_divider" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Net movement"
                        android:textColor="@color/kitatrack_secondary_text" />
                    <TextView
                        android:id="@+id/month_net_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/kitatrack_primary_green"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_soft_planner_background"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="Reserved Money" />
                <TextView
                    android:id="@+id/reserved_money_summary"
                    style="@style/KitaTrackBodyText"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_soft_mint"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="Smart Insight" />
                <TextView
                    android:id="@+id/smart_insight_value"
                    style="@style/KitaTrackBodyText"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_soft_warning_background"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="Upcoming Obligations" />
                <TextView
                    android:id="@+id/obligations_value"
                    style="@style/KitaTrackBodyText"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="Budget Pulse" />
                <TextView
                    android:id="@+id/budget_pulse_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/budget_pulse_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progressTint="@color/kitatrack_primary_green"
                    android:progressBackgroundTint="@color/kitatrack_divider" />
                <TextView
                    android:id="@+id/budget_hint_value"
                    style="@style/KitaTrackBodyText"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_soft_planner_background"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    style="@style/KitaTrackSectionTitle"
                    android:text="Savings Goals" />
                <TextView
                    android:id="@+id/piggy_overview_value"
                    style="@style/KitaTrackBodyText"
                    android:layout_marginTop="8dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/view_plans_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="View Plans"
                    android:textAllCaps="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
