<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/kt_bottom_sheet_background"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/kt_sheet_handle" />

    <TextView
        android:id="@+id/subscription_actions_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="@color/kitatrack_primary_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subscription_actions_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Subscription actions"
        android:textColor="@color/kitatrack_secondary_text"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/subscription_actions_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/kt_form_field_background"
        android:orientation="vertical" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/subscription_actions_cancel"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="@color/kitatrack_secondary_text" />
</LinearLayout>
