<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kt_screen_background"
    android:clipToPadding="false"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Local and offline-first."
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settings_theme_toggle_button"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Toggle dark mode"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/kitatrack_elevated_card_background"
                app:cornerRadius="22dp"
                app:icon="@drawable/ic_theme_moon"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/kitatrack_primary_text" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.16"
            android:text="DATA &amp; BACKUP"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/export_csv_button"
                    layout="@layout/item_settings_action_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:background="@color/kitatrack_divider" />

                <include
                    android:id="@+id/export_json_button"
                    layout="@layout/item_settings_action_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:background="@color/kitatrack_divider" />

                <include
                    android:id="@+id/import_json_button"
                    layout="@layout/item_settings_action_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:background="@color/kitatrack_divider" />

                <include
                    android:id="@+id/reset_data_button"
                    layout="@layout/item_settings_action_row" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/backup_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <include
            layout="@layout/settings_backup_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.16"
            android:text="REMINDERS &amp; NOTIFICATIONS"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/notification_permission_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/kitatrack_soft_warning_background"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_warning_yellow"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="!"
                    android:textColor="@color/kitatrack_warning_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Notifications blocked"
                        android:textColor="@color/kitatrack_primary_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/notification_permission_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Reminders won't fire until you allow them in system settings."
                        android:textColor="@color/kitatrack_secondary_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/request_notifications_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:text="Allow"
                    android:textAllCaps="false"
                    android:textColor="@color/kitatrack_primary_green" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/master_reminders_switch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Enable reminders"
                    android:textColor="@color/kitatrack_primary_text" />

                <View style="@style/KitaTrackSettingsDivider" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/debt_reminders_switch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Debt reminders"
                    android:textColor="@color/kitatrack_secondary_text" />

                <View style="@style/KitaTrackSettingsDivider" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/subscription_reminders_switch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Subscription reminders"
                    android:textColor="@color/kitatrack_secondary_text" />

                <View style="@style/KitaTrackSettingsDivider" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/budget_alerts_switch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Budget alerts"
                    android:textColor="@color/kitatrack_secondary_text" />

                <View style="@style/KitaTrackSettingsDivider" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/piggy_reminders_switch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Piggy bank reminders"
                    android:textColor="@color/kitatrack_secondary_text" />

                <View style="@style/KitaTrackSettingsDivider" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/missed_reminders_switch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Missed contribution reminders"
                    android:textColor="@color/kitatrack_secondary_text" />

                <View style="@style/KitaTrackSettingsDivider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Default timing"
                            android:textColor="@color/kitatrack_primary_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="When to fire each reminder"
                            android:textColor="@color/kitatrack_secondary_text"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/reminder_timing_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:hint="">

                        <AutoCompleteTextView
                            android:id="@+id/reminder_timing_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refresh_reminders_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="Refresh Reminder Schedule"
            android:textAllCaps="false"
            app:cornerRadius="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Reminders are local to this device. No cloud sync or backend."
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.16"
            android:text="AI MONTHLY ANALYSIS"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/kitatrack_card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/kitatrack_subtle_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/kt_icon_circle"
                    android:backgroundTint="@color/kitatrack_soft_ai_background"
                    android:gravity="center"
                    android:text="AI"
                    android:textColor="@color/kitatrack_ai_purple"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI monthly analysis"
                        android:textColor="@color/kitatrack_primary_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Uses summarized totals only. Raw notes are never sent."
                        android:textColor="@color/kitatrack_secondary_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/ai_monthly_summary_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
