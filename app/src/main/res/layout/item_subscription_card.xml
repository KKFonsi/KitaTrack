<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"
    app:cardBackgroundColor="@color/kitatrack_soft_warning_background" app:cardCornerRadius="24dp" app:strokeColor="@color/kitatrack_subtle_border" app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView android:id="@+id/subscription_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:textColor="@color/kitatrack_primary_text" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/subscription_amount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/kitatrack_primary_green" android:textSize="17sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:id="@+id/subscription_meta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/kitatrack_secondary_text" android:textSize="14sp" />
        <ProgressBar android:id="@+id/subscription_reserve_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="7dp" android:layout_marginTop="12dp" android:max="100" android:progressTint="@color/kitatrack_primary_green" android:progressBackgroundTint="@color/kitatrack_divider" />
        <TextView android:id="@+id/subscription_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/kt_chip_green" android:paddingLeft="10dp" android:paddingTop="4dp" android:paddingRight="10dp" android:paddingBottom="4dp" android:textColor="@color/kitatrack_primary_green" android:textSize="12sp" android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

