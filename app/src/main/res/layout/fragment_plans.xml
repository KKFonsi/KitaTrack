<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kt_screen_background"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Plans"
                    android:textColor="@color/kitatrack_primary_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Budgets, savings, debts, and bills."
                    android:textColor="@color/kitatrack_secondary_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/plans_theme_toggle_button"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="Toggle dark mode"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/kitatrack_elevated_card_background"
                app:cornerRadius="22dp"
                app:icon="@drawable/ic_theme_moon"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/kitatrack_primary_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_plans_budget"
                app:tint="@color/kitatrack_primary_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Budgets"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/budget_count_badge"
                style="@style/KitaTrackStatusChipText"
                android:layout_marginStart="8dp"
                android:background="@drawable/kt_chip_green"
                android:text="0" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_budget_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="+ Add"
                android:textAllCaps="false"
                android:textColor="@color/kitatrack_primary_green"
                app:cornerRadius="19dp"
                app:strokeColor="@color/kitatrack_subtle_border" />
        </LinearLayout>

        <TextView
            android:id="@+id/budget_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/kt_plan_empty_card"
            android:padding="16dp"
            android:text="No budgets yet."
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/budget_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manage_categories_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:text="Manage Categories"
            android:textAllCaps="false"
            android:textColor="@color/kitatrack_secondary_text"
            app:cornerRadius="16dp"
            app:strokeColor="@color/kitatrack_subtle_border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_plans_piggy_bank"
                app:tint="@color/kitatrack_primary_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Piggy Banks"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/piggy_count_badge"
                style="@style/KitaTrackStatusChipText"
                android:layout_marginStart="8dp"
                android:background="@drawable/kt_chip_green"
                android:text="0" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_piggy_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="+ Add"
                android:textAllCaps="false"
                android:textColor="@color/kitatrack_primary_green"
                app:cornerRadius="19dp"
                app:strokeColor="@color/kitatrack_subtle_border" />
        </LinearLayout>

        <TextView
            android:id="@+id/piggy_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/kt_plan_empty_card"
            android:padding="16dp"
            android:text="No piggy banks yet."
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/piggy_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_plans_debt"
                app:tint="@color/kitatrack_primary_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Debts"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/debt_count_badge"
                style="@style/KitaTrackStatusChipText"
                android:layout_marginStart="8dp"
                android:background="@drawable/kt_chip_green"
                android:text="0" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_debt_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="+ Add"
                android:textAllCaps="false"
                android:textColor="@color/kitatrack_primary_green"
                app:cornerRadius="19dp"
                app:strokeColor="@color/kitatrack_subtle_border" />
        </LinearLayout>

        <TextView
            android:id="@+id/debt_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/kt_plan_empty_card"
            android:padding="16dp"
            android:text="No debts yet."
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/debt_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_plans_subscription"
                app:tint="@color/kitatrack_primary_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Subscriptions"
                android:textColor="@color/kitatrack_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subscription_count_badge"
                style="@style/KitaTrackStatusChipText"
                android:layout_marginStart="8dp"
                android:background="@drawable/kt_chip_green"
                android:text="0" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_subscription_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="+ Add"
                android:textAllCaps="false"
                android:textColor="@color/kitatrack_primary_green"
                app:cornerRadius="19dp"
                app:strokeColor="@color/kitatrack_subtle_border" />
        </LinearLayout>

        <TextView
            android:id="@+id/subscription_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/kt_plan_empty_card"
            android:padding="16dp"
            android:text="No subscriptions yet."
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/subscription_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
