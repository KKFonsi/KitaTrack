<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kt_screen_background">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            style="@style/KitaTrackScreenTitle"
            android:text="Plans" />
        <TextView
            style="@style/KitaTrackScreenSubtitle"
            android:text="Budgets, savings, debts, and bills in one planning board." />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="22dp" android:text="Budgets"
            android:textColor="@color/kitatrack_primary_text" android:textSize="20sp" android:textStyle="bold"/>
        <TextView android:id="@+id/budget_empty_state" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="12dp"
            android:background="@drawable/kt_card_warning" android:padding="18dp"
            android:text="No budgets yet. Create a weekly or monthly budget to start tracking your spending."
            android:textColor="@color/kitatrack_secondary_text"/>
        <LinearLayout android:id="@+id/budget_list" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/add_budget_button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:minHeight="52dp" android:text="Add Budget" android:textAllCaps="false"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/manage_categories_button"
            style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="8dp"
            android:text="Manage Categories" android:textAllCaps="false"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="26dp" android:text="Piggy Banks"
            android:textColor="@color/kitatrack_primary_text" android:textSize="20sp" android:textStyle="bold"/>
        <TextView android:id="@+id/piggy_empty_state" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="12dp"
            android:background="@drawable/kt_card_warning" android:padding="18dp"
            android:text="No savings goals yet. Create a piggy bank for something you want to save for."
            android:textColor="@color/kitatrack_secondary_text"/>
        <LinearLayout android:id="@+id/piggy_list" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/add_piggy_button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:minHeight="52dp" android:text="Add Piggy Bank" android:textAllCaps="false"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="26dp" android:text="Debts"
            android:textColor="@color/kitatrack_primary_text" android:textSize="20sp" android:textStyle="bold"/>
        <TextView android:id="@+id/debt_empty_state" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="12dp"
            android:background="@drawable/kt_card_warning" android:padding="18dp"
            android:text="No active debts. Add a debt if you want payment reminders and reserve tracking."
            android:textColor="@color/kitatrack_secondary_text"/>
        <LinearLayout android:id="@+id/debt_list" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/add_debt_button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:minHeight="52dp" android:text="Add Debt" android:textAllCaps="false"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="26dp" android:text="Subscriptions"
            android:textColor="@color/kitatrack_primary_text" android:textSize="20sp" android:textStyle="bold"/>
        <TextView android:id="@+id/subscription_empty_state" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="12dp"
            android:background="@drawable/kt_card_warning" android:padding="18dp"
            android:text="No subscriptions tracked. Track recurring payments so they do not surprise you."
            android:textColor="@color/kitatrack_secondary_text"/>
        <LinearLayout android:id="@+id/subscription_list" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/add_subscription_button"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:minHeight="52dp" android:text="Add Subscription" android:textAllCaps="false"/>
    </LinearLayout>
</ScrollView>

