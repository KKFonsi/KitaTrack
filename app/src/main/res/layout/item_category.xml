<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="10dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/kt_category_icon_circle">

        <ImageView
            android:id="@+id/category_icon"
            android:layout_width="19dp"
            android:layout_height="19dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            app:tint="@color/kitatrack_secondary_text" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/category_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/category_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/edit_category_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:minWidth="0dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="Edit"
        android:textAllCaps="false"
        android:textColor="@color/kitatrack_secondary_text" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/delete_category_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:text=""
        app:icon="@drawable/ic_delete_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@color/kitatrack_expense_red" />
</LinearLayout>
