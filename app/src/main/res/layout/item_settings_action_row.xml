<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="12dp">

    <TextView
        android:id="@+id/settings_action_icon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/kt_icon_circle"
        android:gravity="center"
        android:textColor="@color/kitatrack_primary_green"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/settings_action_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/kitatrack_primary_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settings_action_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/kitatrack_secondary_text"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="›"
        android:textColor="@color/kitatrack_muted_text"
        android:textSize="24sp" />
</LinearLayout>
